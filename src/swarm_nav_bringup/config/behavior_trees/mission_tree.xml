<?xml version="1.0"?>
<!-- mission_tree.xml -->
<!-- BehaviorTree.CPP v4 mission tree for exploration coordination -->

<root BTCPP_format="4" main_tree_to_execute="ExplorationMission">
  
  <BehaviorTree ID="ExplorationMission">
    <Sequence name="MainSequence">
      
      <!-- Repeat exploration until coverage threshold met -->
      <KeepRunningUntilFailure name="ExplorationLoop">
        <Sequence name="ExplorationCycle">
          
          <!-- Check if map coverage is sufficient -->
          <Inverter name="InvertCoverageCheck">
            <MapCoverageCheck coverage_threshold="0.95" name="CheckCoverage"/>
          </Inverter>
          
          <!-- Safely try to detect, auction, and navigate -->
          <Fallback name="SafeExplorationStep">
            <Sequence name="DoExploration">
              <!-- Detect frontiers -->
              <FrontierDetectorBT name="DetectFrontiers" frontier_count="{frontier_count}"/>
              
              <!-- Run Vickrey auction for task allocation -->
              <RunAuctionBT name="RunAuction" 
                            frontier_count="{frontier_count}"
                            assigned_frontier="{assigned_frontier}"/>
              
              <!-- Navigate to assigned frontier -->
              <NavigateToPose goal="{assigned_frontier}" 
                             server_name="navigate_to_pose"
                             name="NavigateAction"/>
            </Sequence>
            
            <!-- If any step fails (e.g. no frontiers, auction timeout, or nav failure), 
                 we fall back here so the main loop continues -->
            <AlwaysSuccess name="IgnoreTransientFailures"/>
          </Fallback>
          
          <!-- Small delay before next cycle -->
          <Delay delay_msec="1000" name="CycleDelay">
            <AlwaysSuccess/>
          </Delay>
          
        </Sequence>
      </KeepRunningUntilFailure>
      
      <!-- Mission complete -->
      <AlwaysSuccess name="MissionComplete"/>
      
    </Sequence>
  </BehaviorTree>
  
</root>
